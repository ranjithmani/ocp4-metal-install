$TTL    604800
@       IN      SOA     ocp-svc.ocp.lan. contact.ocp.lan (
                  4     ; Serial
             604800     ; Refresh
              86400     ; Retry
            2419200     ; Expire
             604800     ; Minimum
)
        IN      NS      ocp-svc

ocp-svc.ocp.lan.          IN      A       192.168.122.2

; Temp Bootstrap Node
ocp-bootstrap.lab.ocp.lan.        IN      A      192.168.122.200

; Control Plane Nodes
ocp-cp-1.lab.ocp.lan.         IN      A      192.168.122.201
ocp-cp-2.lab.ocp.lan.         IN      A      192.168.122.202
ocp-cp-3.lab.ocp.lan.         IN      A      192.168.122.203

; Worker Nodes
ocp-wk-1.lab.ocp.lan.        IN      A      192.168.122.211
ocp-wk-2.lab.ocp.lan.        IN      A      192.168.122.212

; OpenShift Internal - Load balancer
api.lab.ocp.lan.        IN    A    192.168.122.2
api-int.lab.ocp.lan.    IN    A    192.168.122.2
*.apps.lab.ocp.lan.     IN    A    192.168.122.2

; ETCD Cluster
etcd-0.lab.ocp.lan.    IN    A     192.168.122.201
etcd-1.lab.ocp.lan.    IN    A     192.168.122.202
etcd-2.lab.ocp.lan.    IN    A     192.168.122.203

; OpenShift Internal SRV records (cluster name = lab)
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-0.lab
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-1.lab
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-2.lab

oauth-openshift.apps.lab.ocp.lan.     IN     A     192.168.122.2
console-openshift-console.apps.lab.ocp.lan.     IN     A     192.168.122.2
